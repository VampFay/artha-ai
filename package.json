{
  "name": "nextjs_tailwind_shadcn_ts",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000 2>&1 | tee dev.log",
    "build": "next build && cp -r .next/static .next/standalone/.next/ && cp -r public .next/standalone/",
    "start": "NODE_ENV=production bun .next/standalone/server.js 2>&1 | tee server.log",
    "lint": "eslint .",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset",
    "db:push:postgres": "prisma db push --schema prisma/schema.postgres.prisma",
    "db:generate:postgres": "prisma generate --schema prisma/schema.postgres.prisma",
    "migrate:to-postgres": "bun run scripts/migrate-sqlite-to-postgres.ts",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-kms": "^3.1083.0",
    "@aws-sdk/client-s3": "^3.1081.0",
    "@aws-sdk/client-secrets-manager": "^3.1083.0",
    "@aws-sdk/client-sqs": "^3.1083.0",
    "@aws-sdk/s3-request-presigner": "^3.1081.0",
    "@prisma/client": "^6.11.1",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-toast": "^1.2.14",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "ioredis": "^5.11.1",
    "jose": "^6.2.3",
    "lucide-react": "^0.525.0",
    "motion": "^12.42.2",
    "next": "^16.1.1",
    "papaparse": "^5.5.4",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.19.1",
    "prisma": "^7.8.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "swr": "^2.4.2",
    "tailwind-merge": "^3.3.1",
    "xlsx": "^0.18.5",
    "z-ai-web-dev-sdk": "^0.0.18",
    "zod": "^4.0.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/vite": "^4.3.2",
    "@types/bcryptjs": "^3.0.0",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.10",
    "bun-types": "^1.3.4",
    "eslint": "^9",
    "eslint-config-next": "^16.1.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
