    "date-fns": "^4.4.0",
    "jose": "^6.2.3",
    "lucide-react": "^0.525.0",
    "motion": "^12.42.2",
    "next": "^16.1.1",
    "papaparse": "^5.5.4",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.19.1",
    "prisma": "^6.11.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
