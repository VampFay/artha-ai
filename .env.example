# ============================================================
# Artha AI — Environment Variables
# ============================================================

# ---- Database ----
# SQLite (development — default)
DATABASE_URL=file:/home/z/my-project/db/custom.db

# PostgreSQL (production — uncomment and set)
# DATABASE_URL=postgresql://artha:artha_password@localhost:5432/artha

# ---- Auth ----
# JWT secret — generate with: openssl rand -hex 32
JWT_SECRET=your-super-secret-key-change-this-in-production

# ---- File Storage ----
# Driver: "local" (default) or "s3"
STORAGE_DRIVER=local

# S3 Configuration (only needed if STORAGE_DRIVER=s3)
# S3_BUCKET=artha-ai-documents
# S3_REGION=ap-south-1
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key
# S3_ENDPOINT= (for Cloudflare R2: https://xxx.r2.cloudflarestorage.com)

# ---- Redis (optional — for rate limiting + job queue) ----
# REDIS_URL=redis://localhost:6379

# ---- Migration ----
# Used by scripts/migrate-sqlite-to-postgres.ts
# SQLITE_URL=file:/home/z/my-project/db/custom.db
# POSTGRES_URL=postgresql://artha:artha_password@localhost:5432/artha
